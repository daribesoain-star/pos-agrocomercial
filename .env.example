# ============================================================
# POS Distribuidora Agrocomercial - Variables de Entorno
# ============================================================

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pos_agrocomercial?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Kame ERP (api.kameone.cl)
KAME_CLIENT_ID="tu_client_id_auth0"
KAME_CLIENT_SECRET="tu_client_secret_auth0"
KAME_TOKEN_URL="https://api.kameone.cl/oauth/token"
KAME_API_URL="https://api.kameone.cl/api"
KAME_USUARIO="usuario@tuempresa.cl"

# Factur-AI (gateway de pagos)
FACTUR_AI_URL="https://api.factur-ai.cl"
FACTUR_AI_API_KEY=""

# App
NODE_ENV="development"
PORT=3001
JWT_SECRET="cambiar-esto-por-un-secret-de-al-menos-32-caracteres"
NEXTAUTH_URL="http://localhost:3000"
